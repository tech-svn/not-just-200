# Website URLs to monitor (JSON format)
# Format: [{"name":"Site Name","url":"https://example.com","timeoutMs":30000}]
WEBSITE_URLS=[{"name":"Example Site","url":"https://example.com","timeoutMs":30000}]

# Allowed domains for monitoring (comma-separated list of root domains only)
# All subdomains of these root domains will automatically be included
# Example: saramin.vn,topdev.vn (includes www.saramin.vn, api.saramin.vn, etc.)
# Leave empty to check all domains (no filtering)
ALLOWED_DOMAINS=

# Telegram Configuration
# Get botToken from @BotFather (https://t.me/BotFather)
# Get chatId by sending a message to your bot and calling:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
