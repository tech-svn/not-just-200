{
  "check": {
    "waitUntil": "networkidle",
    "networkIdleTimeoutMs": 30000,
    "maxAllowedLoadTimeMs": 40000,
    "ignoreStatusCodesForDomains": [],
    "screenshotOnError": true
  },

  "telegram": {
    "sendOkNotification": false
  },

  "storage": {
    "logDir": "./logs",
    "screenshotDir": "./screenshots",
    "keepLogsForDays": 14
  }
}
