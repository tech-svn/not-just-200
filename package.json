    "worker:tail": "wrangler tail"
  },
  "dependencies": {
    "@cloudflare/playwright": "^1.3.0",
    "dotenv": "^16.3.1",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "wrangler": "^4.112.0"
  }
}
